{
  "JwtSettings": {
    "SecretKey": "ShopEZSuperSecretKey2025ForJWTTokenGeneration!!",
    "Issuer": "ShopEZ",
    "Audience": "ShopEZ"
  },
  "AllowedOrigins": "http://localhost:4200",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" },
        "Transforms": [
          { "RequestHeadersCopy": "true" }
        ]
      },
      "products-route": {
        "ClusterId": "product-cluster",
        "Match": { "Path": "/api/products/{**catch-all}" },
        "Transforms": [
          { "RequestHeadersCopy": "true" }
        ]
      },
      "categories-route": {
        "ClusterId": "product-cluster",
        "Match": { "Path": "/api/categories/{**catch-all}" },
        "Transforms": [
          { "RequestHeadersCopy": "true" }
        ]
      },
      "cart-route": {
        "ClusterId": "cart-cluster",
        "Match": { "Path": "/api/cart/{**catch-all}" },
        "Transforms": [
          { "RequestHeadersCopy": "true" }
        ]
      },
      "orders-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/api/orders/{**catch-all}" },
        "Transforms": [
          { "RequestHeadersCopy": "true" }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-service": { "Address": "https://localhost:7001" }
        }
      },
      "product-cluster": {
        "Destinations": {
          "product-service": { "Address": "https://localhost:7002" }
        }
      },
      "cart-cluster": {
        "Destinations": {
          "cart-service": { "Address": "https://localhost:7003" }
        }
      },
      "order-cluster": {
        "Destinations": {
          "order-service": { "Address": "https://localhost:7004" }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*"
}